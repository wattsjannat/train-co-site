# Local Development Configuration
# Copy this file to .env.local and fill in your values.
# Get your dev API key from: Dashboard > Websites > [Your Site] > Local Development

NEXT_PUBLIC_WIDGET_API_KEY=vk_dev_your_key_here
NEXT_PUBLIC_WIDGET_HOST=https://app.mobeus.ai

# MCP Server Configuration
# For AWS deployments on train-v1, use the local MCP endpoint
# This will be available at http://localhost:8080/mcp when running on AWS
MCP_SERVER_URL=https://train-v1.rapidprototype.ai/mcp
