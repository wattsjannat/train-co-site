# Production Environment Variables for Mobeus Deployment

# API Configuration
NEXT_PUBLIC_API_URL=https://your-domain.com

# Agent Configuration
NEXT_PUBLIC_AGENT_NAME=Trainco AI

# Development/Staging (optional)
NEXT_PUBLIC_DEV_TOOLBAR_HOST=your-domain.com

# Node Environment (automatically set in production)
NODE_ENV=production

# Port (default: 3000)
PORT=3000
